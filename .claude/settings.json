{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "COMMAND=\"$CLAUDE_TOOL_INPUT_COMMAND\" bash scripts/hooks/dangerous-cmd-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "TOOL_NAME=\"$CLAUDE_TOOL_NAME\" FILE_PATH=\"$CLAUDE_TOOL_INPUT_FILE_PATH\" bash scripts/hooks/tdd-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "TOOL_NAME=\"$CLAUDE_TOOL_NAME\" EXIT_CODE=\"$CLAUDE_TOOL_RESULT_EXIT_CODE\" OUTPUT=\"$CLAUDE_TOOL_RESULT_OUTPUT\" bash scripts/hooks/circuit-breaker.sh"
          }
        ]
      }
    ]
  }
}
